<Window x:Class="WindowThumbWall.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowThumbWall"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: window picker -->
        <DockPanel Grid.Column="0" Margin="6">
            <TextBlock DockPanel.Dock="Top"
                       Text="🔍 Filter windows:"
                       Foreground="#CCC" Margin="0,0,0,4" FontSize="13"/>
            <TextBox DockPanel.Dock="Top"
                     x:Name="FilterBox"
                     Margin="0,0,0,6"/>
            <TextBlock DockPanel.Dock="Bottom"
                       x:Name="HintText"
                       Text="Double-click → assign to grid.&#x0a;Right-click cell → clear.&#x0a;Left-click cell → maximize / restore."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap"
                       Margin="0,6,0,0"/>
            <ListBox x:Name="WindowList"
                     Background="#2D2D2D" Foreground="White"
                     BorderThickness="0"
                     DisplayMemberPath="Title"/>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="4"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="#444"/>

        <!-- Right panel: 2×2 thumbnail grid (cells built in code-behind) -->
        <Grid Grid.Column="2" x:Name="ThumbGrid" Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
        </Grid>
    </Grid>
</Window>